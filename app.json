{
  "expo": {
    "name": "Mindgames",
    "slug": "mindgames",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "mindgames",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mindgames.app",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Mindgames sends an optional daily reminder when a new puzzle is available."
      }
    },
    "android": {
      "package": "com.mindgames.app",
      "permissions": ["VIBRATE", "RECEIVE_BOOT_COMPLETED", "SCHEDULE_EXACT_ALARM"]
    },
    "plugins": [
      "expo-notifications"
    ]
  }
}
