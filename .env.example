# Copy this file to .env.local and fill in the values.
# .env.local is gitignored. Never commit real keys.

# RevenueCat Public SDK keys (https://app.revenuecat.com → Project settings → API keys)
# Android key starts with goog_, iOS key starts with appl_. Leave blank in dev to
# fall back to the local AsyncStorage flag for the "remove ads" entitlement.
EXPO_PUBLIC_REVENUECAT_ANDROID=
EXPO_PUBLIC_REVENUECAT_IOS=
